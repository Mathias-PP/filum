# Configuration Filum — fichier exemple
# Copier vers .env et compléter avec les vraies valeurs
# NE JAMAIS commit le fichier .env complété

# === Environnement ===
ENVIRONMENT=development          # development | staging | production
DEBUG=true

# === Backend ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173

# === Base de données PostgreSQL ===
DATABASE_URL=postgresql+asyncpg://filum:filum@localhost:5432/filum
# En production sur Railway, cette variable est fournie automatiquement

# === DuckDB ===
DUCKDB_PATH=./apps/analytics/filum_analytics.duckdb

# === Sécurité ===
# Clé secrète pour signer les sessions JWT (générer avec : openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# Clé maître pour chiffrer les clés privées Ed25519 des utilisateurs au repos
# Format : base64url-encoded 32 bytes (générer avec : python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())")
MASTER_ENCRYPTION_KEY=change-me-to-a-random-base64-key

# === OAuth Google ===
# Créer le projet sur https://console.cloud.google.com/
# Activer "Google Identity API"
# Créer un OAuth 2.0 Client ID de type "Web application"
# URI de redirection : http://localhost:8000/api/v1/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Wayback Machine ===
# Pas d'authentification nécessaire pour usage modéré
# Pour usage plus intensif (phase 2+), créer un compte Internet Archive et obtenir des credentials S3-like
WAYBACK_USER_AGENT="Filum/0.1 (https://filum.app; contact@filum.app)"
# Pour usage intensif :
# WAYBACK_S3_ACCESS_KEY=
# WAYBACK_S3_SECRET_KEY=

# === CORS ===
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# En production, mettre uniquement l'URL du frontend en production

# === Rate limiting ===
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTHENTICATED=200/minute

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json                  # json | text

# === Frontend (variables exposées au client, préfixées PUBLIC_) ===
PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
PUBLIC_SITE_BASE_URL=http://localhost:5173
PUBLIC_SITE_NAME=Filum
PUBLIC_GA_TRACKING_ID=           # vide en MVP — pas de Google Analytics
