{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "CLAUDE.md",
    "agent/README.md",
    "agent/PERMISSIONS.md",
    "agent/GIT_WORKFLOW.md",
    "agent/SECURITY.md",
    "agent/PITFALLS.md",
    "agent/TASK_PROTOCOL.md",
    "agent/memory/PROJECT_SNAPSHOT.md",
    "agent/memory/INDEX.md",
    ".docs/10-mvp-completion-plan.md",
    "STATE.md"
  ],
  "permission": {
    "edit": "allow",
    "webfetch": "allow",
    "bash": {
      "git status": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git fetch*": "allow",
      "git branch*": "allow",
      "git checkout -b *": "allow",
      "git checkout *": "ask",
      "git add *": "allow",
      "git commit *": "allow",
      "git push origin main": "deny",
      "git push origin main *": "deny",
      "git push --force origin main*": "deny",
      "git push origin HEAD:main*": "deny",
      "git push *": "allow",
      "git rebase*": "ask",
      "git reset --hard*": "ask",
      "git merge *": "ask",
      "git tag *": "ask",
      "gh pr create *": "allow",
      "gh pr list*": "allow",
      "gh pr view*": "allow",
      "gh pr checks*": "allow",
      "gh pr merge*": "ask",
      "gh run list*": "allow",
      "gh run view*": "allow",
      "gh workflow run *": "ask",
      "uv sync*": "allow",
      "uv add *": "ask",
      "uv remove *": "ask",
      "uv run pytest*": "allow",
      "uv run ruff*": "allow",
      "uv run mypy*": "allow",
      "uv run alembic upgrade head": "allow",
      "uv run alembic downgrade*": "ask",
      "uv run alembic revision*": "allow",
      "uv run uvicorn*": "allow",
      "uv run *": "allow",
      "pnpm install --frozen-lockfile": "allow",
      "pnpm install*": "ask",
      "pnpm add *": "ask",
      "pnpm remove *": "ask",
      "pnpm run lint*": "allow",
      "pnpm run check*": "allow",
      "pnpm run test*": "allow",
      "pnpm run build*": "allow",
      "pnpm run dev*": "allow",
      "pnpm run format*": "allow",
      "pnpm *": "ask",
      "make *": "allow",
      "docker compose up*": "ask",
      "docker compose down*": "ask",
      "docker *": "ask",
      "curl https://filum-production-07bb.up.railway.app/health*": "allow",
      "curl https://filum-eight.vercel.app/*": "allow",
      "curl https://api.crossref.org/*": "allow",
      "curl https://web.archive.org/*": "allow",
      "curl *": "ask",
      "wsl *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "echo *": "allow",
      "pwd": "allow",
      "cd *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "cp *": "ask",
      "mv *": "ask",
      "rm *": "deny",
      "rm -rf *": "deny",
      "sudo *": "deny",
      "chmod *": "ask",
      "chown *": "deny",
      "kill *": "ask",
      "pkill *": "deny",
      "*": "ask"
    }
  },
  "_comments": {
    "purpose": "Configuration opencode pour le projet Filum. Voir agent/README.md pour le système d'instructions complet.",
    "rationale_permissions": "Lectures et builds quotidiens en allow. Toute action mutante sur main, sur les deps, ou sur le système est en ask. rm en deny par principe : préférer git rm.",
    "rationale_instructions": "L'ordre des fichiers chargés reflète la priorité : règles globales (AGENTS/CLAUDE) > règles agent (PERMISSIONS, GIT, SECURITY, PITFALLS) > contexte projet (SNAPSHOT, STATE) > plan actuel.",
    "model_choice": "Le model n'est pas spécifié ici pour laisser l'utilisateur choisir via opencode CLI. Recommandé : claude-sonnet-4-6 ou claude-opus-4-6 pour les tâches sensibles."
  }
}
