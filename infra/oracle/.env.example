# ============================================================
# Configuration VM Oracle — infra/oracle/.env
# Copier vers .env sur la VM et compléter. NE JAMAIS COMMITER .env.
# Secrets : openssl rand -hex 32
# ⚠️ ADR-010 : variables backend en lowercase obligatoire.
# ============================================================

# === Domaine public de l'API (DuckDNS ou domaine custom) ===
# Utilisé par Caddy pour le TLS automatique.
API_DOMAIN=philum-api.duckdns.org

# === PostgreSQL (conteneur local — variante ARM docker-compose.yml uniquement) ===
POSTGRES_USER=philum
POSTGRES_PASSWORD=CHANGER_MOI_openssl_rand_hex_32
POSTGRES_DB=philum

# === Base externe (variante E2.1.Micro docker-compose.micro.yml uniquement) ===
# Connection string Supabase (Dashboard → Connect → "Session pooler", port 5432).
# ⚠️ PAS le "Transaction pooler" (6543) : il casse les prepared statements
# d'asyncpg/SQLAlchemy. Le préfixe postgresql:// est converti en
# postgresql+asyncpg:// automatiquement par le backend.
# Laisser vide avec la variante ARM (injecté par docker-compose.yml).
database_url=

# === Backend FastAPI ===
# Variante ARM : database_url est injecté automatiquement par docker-compose.yml
# (pointe vers le conteneur postgres) — ne pas le définir ci-dessus.
session_secret=GENERER_openssl_rand_hex_32
master_encryption_key=REPRENDRE_LA_CLE_RAILWAY_SINON_LES_CLES_PRIVEES_EXISTANTES_SONT_ILLISIBLES
google_client_id=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
google_client_secret=YOUR_GOOGLE_CLIENT_SECRET

frontend_base_url=https://filum-eight.vercel.app
backend_base_url=https://philum-api.duckdns.org
cors_origins=["https://filum-eight.vercel.app"]

rate_limit_per_minute=60
wayback_api_key=
debug=false
