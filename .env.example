# ============================================================
# Configuration Filum — fichier exemple
# ============================================================
# INSTRUCTIONS :
# 1. Copier ce fichier vers .env : cp .env.example .env
# 2. Compléter avec les vraies valeurs pour votre environnement
# 3. GÉNÉRER les secrets avec les commandes ci-dessous :
#
#    # Générer session_secret (64 caractères hex)
#    openssl rand -hex 32
#
#    # Générer master_encryption_key (64 caractères hex)
#    openssl rand -hex 32
#
# 4. NE JAMAIS commiter le fichier .env complété
# 5. Les Credentials Google OAuth doivent être créés sur Google Cloud Console
#
# ⚠️ IMPORTANT — convention de nommage (cf. ADR-010) :
# pydantic-settings tourne en case_sensitive=True. Les variables ci-dessous
# DOIVENT rester en lowercase. UPPERCASE → silent fallback aux défauts en
# Linux/CI (Windows masque le bug par accident).
# ============================================================

# === PostgreSQL (Transactionnel) ===
# Format: postgresql+asyncpg://user:password@host:port/database
database_url=postgresql+asyncpg://filum:YOUR_PASSWORD@localhost:5432/filum_dev
database_pool_size=5
database_max_overflow=10

# === Session & Crypto (OBLIGATOIRE - générer avec openssl) ===
# Ces secrets NE DOIVENT PAS être communs ou devinables
session_secret=GENERER_AVEC_openssl_rand_hex_32
master_encryption_key=GENERER_AVEC_openssl_rand_hex_32

# === OAuth Google (créer sur Google Cloud Console) ===
# https://console.cloud.google.com/apis/credentials
# Créer un OAuth 2.0 Client ID pour application Web
google_client_id=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
google_client_secret=YOUR_GOOGLE_CLIENT_SECRET
google_redirect_uri=http://localhost:8000/api/v1/auth/google/callback

# === URLs ===
frontend_base_url=http://localhost:5173
backend_base_url=http://localhost:8000
api_v1_prefix=/api/v1

# === CORS (Liste des origins autorisées en production) ===
# Format JSON array - NE PAS inclure localhost en production
cors_origins=["http://localhost:5173"]

# === Rate Limiting ===
rate_limit_per_minute=60

# === Wayback Machine (optionnel) ===
# https://archive.org/help/api.php
wayback_api_key=

# === Proxy LiteLLM (optionnel — cf. .docs/17-llm-strategy.md) ===
# Vide = couche LLM désactivée (extraction heuristique seule).
# En prod Oracle : http://litellm:4000 (injecté par l'overlay compose).
litellm_base_url=
litellm_master_key=

# === SvelteKit /api proxy → FastAPI backend ===
# Server-side variable read by apps/frontend/src/routes/api/[...path]/+server.ts
# Must be set on the frontend deployment (Vercel) to the public hostname
# of the FastAPI backend, e.g. https://filum-api.up.railway.app
# Required for first-party cookies (mobile Safari/iOS WebKit blocks
# cross-origin session cookies via ITP). See ADR-025.
BACKEND_URL=http://localhost:8000

# === PUBLIC_API_BASE_URL: do NOT set in production ===
# Legacy variable. The frontend now always uses a relative `/api/v1/...` path
# in the browser (routed through the SvelteKit proxy above). If you set this
# to an absolute URL in production, browser requests will bypass the proxy
# and you'll re-introduce the third-party cookie bug on mobile.
# Keep unset on Vercel. Local dev works either way (vite proxies /api anyway).
# PUBLIC_API_BASE_URL=

# === Analytics (DuckDB path) ===
duckdb_path=/data/filum_analytics.duckdb

# === Développement ===
debug=false
