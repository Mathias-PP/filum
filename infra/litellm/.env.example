# ============================================================
# Clés providers LLM — infra/litellm/.env
# Copier vers .env sur la VM. NE JAMAIS COMMITER .env.
# Tous les providers ci-dessous ont un free tier (limites vérifiées
# 2026-07-16, cf. .docs/17-llm-strategy.md §2) — re-vérifier avant setup.
# ============================================================

# Clé d'accès AU proxy (le backend l'utilise comme api_key).
# Générer : openssl rand -hex 32
LITELLM_MASTER_KEY=sk-CHANGER_MOI

# https://aistudio.google.com/apikey — 1 500 req/j Gemini 3 Flash.
# ⚠️ NE PAS activer le billing sur le projet GCP : ça supprime le free tier.
GEMINI_API_KEY=

# https://console.mistral.ai — tier Experiment (~1 Md tokens/mois, EU).
MISTRAL_API_KEY=

# https://console.groq.com — 30 RPM / 1 000-14 400 req/j.
GROQ_API_KEY=

# https://cloud.cerebras.ai — 1 M tokens/j (contexte 8k max).
CEREBRAS_API_KEY=
