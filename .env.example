# PostgreSQL (Transactionnel)
DATABASE_URL=postgresql+asyncpg://filum:filum_dev_password@localhost:5432/filum_dev
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Session & Crypto
SESSION_SECRET=change_me_generate_with_openssl_rand_hex_32
MASTER_ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32

# OAuth Google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# URLs
FRONTEND_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:8000
API_V1_PREFIX=/api/v1

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Wayback Machine (optionnel)
WAYBACK_API_KEY=optional_api_key

# Analytics (DuckDB path)
DUCKDB_PATH=/data/filum_analytics.duckdb
